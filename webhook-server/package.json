{
  "name": "healthclaw-webhook-server",
  "version": "0.2.0",
  "description": "Webhook server for receiving Apple Health data",
  "main": "dist/index.js",
  "bin": {
    "healthclaw-webhook": "dist/bin.js"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "prebuild": "rm -rf dist",
    "build": "rspack build --config rspack.config.cjs",
    "build:tsc": "tsgo",
    "postbuild": "chmod +x dist/bin.js",
    "start": "node dist/bin.js",
    "dev": "nodemon index.js",
    "test": "tsx --test 'tests/**/*.test.ts'",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "keywords": [
    "openclaw",
    "health",
    "apple-health",
    "healthkit",
    "webhook"
  ],
  "author": "HealthClaw Contributors",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "body-parser": "^1.20.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@rspack/cli": "^1.7.6",
    "@rspack/core": "^1.7.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@typescript/native-preview": "^7.0.0-dev.20260224.1",
    "eslint": "^8.57.1",
    "nodemon": "^3.0.1",
    "prettier": "^3.4.2",
    "supertest": "^7.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
