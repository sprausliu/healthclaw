# HealthClaw Webhook Server Configuration

# Server Port (default: 3000)
PORT=3000

# Health data storage directory
# Default: webhook-server/data
HEALTH_DATA_DIR=/Users/yourusername/Source/healthclaw/webhook-server/data

# Auth for cleanup/admin endpoints
ADMIN_TOKEN=replace-with-strong-admin-token

# Batch endpoint guardrails
BATCH_MAX_ITEMS=5000
BATCH_MAX_BODY_MB=10

# Dedupe DB path
DEDUPE_DB_PATH=/Users/yourusername/Source/healthclaw/webhook-server/data/dedupe.db

# Persistence Configuration
# Override default user-level app data location (optional)
# Default: ~/.local/share/healthclaw-webhook (Linux), ~/Library/Application Support/healthclaw-webhook (macOS)
# HEALTHCLAW_DATA_DIR=/custom/path/to/data

# Secret backend preference (optional)
# Options: system, file
# Default: system (falls back to file if system unavailable)
# HEALTHCLAW_SECRET_BACKEND=system
